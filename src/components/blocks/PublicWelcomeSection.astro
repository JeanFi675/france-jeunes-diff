---
import BrutalHeading from '../atoms/BrutalHeading.astro';
import BrutalBadge from '../atoms/BrutalBadge.astro';
import BrutalCard from '../atoms/BrutalCard.astro';
import competitionData from '../../data/competition-data.js';

const { publicInfo, competitorsInfo, weatherTips } = competitionData;
---

<section class="brutal-section brutal-section--white">
  <div class="brutal-container">
    <div class="section-header">
      <BrutalHeading level={2} rotation={-1} shadow={true} class="brutal-title">
        UN WEEK-END<br>D'ESCALADE INTENSE
      </BrutalHeading>
    </div>
    
    <div class="two-columns">
      <!-- Colonne PUBLIC -->
      <BrutalCard variant="mint" rotation={1}>
        <BrutalHeading level={3} rotation={1}>
          {publicInfo.subtitle}
        </BrutalHeading>
        <ul class="benefit-list">
          {publicInfo.points.map(point => (
            <li>{point}</li>
          ))}
        </ul>
        <div class="brutal-cta-box">
          {publicInfo.callToAction}
        </div>
      </BrutalCard>
      
      <!-- Colonne COMPÉTITEURS -->
      <BrutalCard variant="black" rotation={-1}>
        <BrutalHeading level={3} rotation={-1}>
          {competitorsInfo.subtitle}
        </BrutalHeading>
        <ul class="benefit-list">
          {competitorsInfo.points.map(point => (
            <li>{point}</li>
          ))}
        </ul>
        <div class="brutal-cta-box brutal-cta-box--mint">
          {competitorsInfo.callToAction}
        </div>
        {competitorsInfo.important && (
          <p style="color: var(--brutal-mint); font-weight: 700; margin-top: 2rem;">
            {competitorsInfo.important}
          </p>
        )}
      </BrutalCard>
    </div>
  </div>
</section>

<style>
  /* Utilise les patterns CSS existants (DRY) */
  .benefit-list {
    list-style: none;
    padding: 0;
    margin: 1rem 0;
  }
  
  .benefit-list li {
    padding: 0.5rem 0;
    border-bottom: 1px solid rgba(0,0,0,0.1);
  }
  
  .benefit-list li:last-child {
    border-bottom: none;
  }
  
  /* Styles h3 supprimés - gérés par BrutalHeading */
  
  /* Style bouton pour le CTA */
  .brutal-cta-box {
    background: var(--brutal-black);
    color: var(--brutal-white);
    font-weight: 900;
    padding: 1rem 1.5rem;
    margin-top: 2rem;
    border: 4px solid var(--brutal-black);
    text-align: center;
    font-size: 1rem;
    text-transform: uppercase;
    transition: all 0.3s ease;
    display: inline-block;
  }
  
  .brutal-cta-box:hover {
    background: var(--brutal-white);
    color: var(--brutal-black);
    transform: translate(-2px, -2px);
  }
  
  /* Styles spécifiques pour benefit-list dans les cartes */
  .brutal-card--mint .benefit-list li {
    border-bottom: 1px solid rgba(0,0,0,0.2);
  }
  
  .brutal-card--black .benefit-list li {
    border-bottom: 1px solid rgba(255,255,255,0.2);
  }
  
  /* Bouton CTA version mint pour compétiteurs */
  .brutal-cta-box--mint {
    background: var(--brutal-mint);
    color: var(--brutal-black);
    border: 4px solid var(--brutal-mint);
  }
  
  .brutal-cta-box--mint:hover {
    background: var(--brutal-black);
    color: var(--brutal-mint);
    border-color: var(--brutal-mint);
  }
</style>