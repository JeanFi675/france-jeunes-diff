---
import { getCollection } from 'astro:content';
import BlogCard from '../atoms/BlogCard.astro';
import BrutalButton from '../atoms/BrutalButton.astro';

// Récupérer les 3 derniers articles de blog triés par date
const latestPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);
---

<section id="news" class="brutal-section brutal-section--white latest-news">
  <div class="brutal-container">
    <div class="section-header">
      <h2 class="section-title">Actualités du Championnat</h2>
      <p class="section-subtitle">Retrouvez les dernières infos, coulisses et annonces officielles</p>
    </div>

    <div class="news-grid">
      {
        latestPosts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            publishDate={post.data.publishDate}
            tags={post.data.tags}
            slug={post.id}
          />
        ))
      }
    </div>

    <div class="section-footer">
      <BrutalButton href="/blog" variant="primary" rotation={1}>
        VOIR TOUTES LES ACTUALITÉS →
      </BrutalButton>
    </div>
  </div>
</section>

<style>
  .latest-news {
    padding: var(--space-large) 0;
    position: relative;
    background-color: var(--brutal-white);
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    margin-bottom: 1rem;
    text-transform: uppercase;
    text-shadow: 4px 4px 0 var(--brutal-ice);
  }

  .section-subtitle {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--brutal-gray);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .news-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2.5rem;
    margin-bottom: 4rem;
  }

  .section-footer {
    display: flex;
    justify-content: center;
    margin-top: 2rem;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .section-header {
      margin-bottom: 2rem;
    }

    .news-grid {
      gap: 1.5rem;
      margin-bottom: 2rem;
    }
  }
</style>
