---
import BrutalHeading from '../atoms/BrutalHeading.astro';
import BrutalBadge from '../atoms/BrutalBadge.astro';
import BrutalButton from '../atoms/BrutalButton.astro';
import BrutalSeparator from '../atoms/BrutalSeparator.astro';
import PartnerLogo from '../atoms/PartnerLogo.astro';

// 🎯 FUSION COUNTDOWN - Calculé AU BUILD TIME pour éliminer friction cognitive
const eventDate = new Date('2026-05-16');
const today = new Date();
const daysLeft = Math.floor((eventDate - today) / (1000 * 60 * 60 * 24));
const isEventSoon = daysLeft < 30;
---

<section class="brutal-section brutal-section--black" style="position: relative; overflow-x: hidden;">
  <!-- Pattern background -->
  <div 
    class="brutal-pattern-diagonal" 
    style="position: absolute; inset: 0; pointer-events: none;"
  ></div>
  
  <!-- Accent blocks - Mobile safe positioning -->
  <div style="position: absolute; top: 10%; right: -5%; width: 250px; height: 250px; background: var(--brutal-mint); opacity: 0.1; transform: rotate(45deg);"></div>
  <div style="position: absolute; bottom: -5%; left: -3%; width: 180px; height: 180px; background: var(--brutal-mint); opacity: 0.1; transform: rotate(-30deg);"></div>
  
  <div class="brutal-container" style="position: relative; z-index: 10; text-align: center; padding: 6rem 2rem;">
    
    <!-- 1. Badge dynamique entrée gratuite + countdown (FUSION UX 2025) -->
    <div style="margin-bottom: 2rem;">
      {isEventSoon ? (
        <BrutalBadge variant="mint" size="large" animated={true} rotation={2}>
          ⏰ J-{daysLeft} • ENTRÉE GRATUITE
        </BrutalBadge>
      ) : (
        <BrutalBadge variant="mint" size="large" animated={true} rotation={2}>
          🎫 ENTRÉE 100% GRATUITE
        </BrutalBadge>
      )}
    </div>
    
    <!-- 2. Logo Championnat France 2026 (dominant) -->
    <div style="margin-bottom: 1rem;">
      <img 
        src={`${import.meta.env.BASE_URL}/logo-championnat-france-2026.svg`}
        alt="Championnat de France 2026" 
        style="max-width: 100%; height: auto; width: clamp(280px, 80vw, 900px); margin: 0 auto; display: block; filter: brightness(0) invert(1);"
      />
    </div>
    
    <!-- 3. Sous-titre jeunes de difficulté (vert, plus petit) -->
    <div style="margin: 1rem 0;">
      <BrutalHeading level={2} shadow={false} rotation={0}>
        <span style="color: var(--brutal-mint); text-shadow: none; -webkit-text-stroke: 0; font-size: var(--size-l4); line-height: 0.9;">
          JEUNES<br>
          DE DIFFICULTÉ
        </span>
      </BrutalHeading>
    </div>
    
    <!-- 4. Trait mint -->
    <BrutalSeparator color="mint" width="60%" margin="2rem auto" />
    
    <!-- 5. Date et lieu OPTIMISÉ (séparation + lisibilité) -->
    <div class="event-info" style="margin: 2.5rem 0;">
      <div style="color: var(--brutal-white); font-size: var(--size-l4); font-weight: 800; text-shadow: none; line-height: 1.2;">
        <div style="margin-bottom: 0.5rem;">
          📅 <strong>16-17 MAI 2026</strong>
        </div>
        <div style="font-size: var(--size-l5); font-weight: 700; opacity: 0.9;">
          📍 SAINT-PIERRE-EN-FAUCIGNY (74)
        </div>
      </div>
    </div>
    
    <!-- 6. Organisé par + logos (layout horizontal) -->
    <div style="margin: 2rem 0;">
      <div style="display: flex; justify-content: center; align-items: center; gap: 2rem; flex-wrap: wrap;">
        <!-- Badge Organisé Par -->
        <span style="
          font-family: 'Inter', Arial, sans-serif;
          font-size: 0.875rem;
          font-weight: 700;
          text-transform: uppercase;
          letter-spacing: 0.1em;
          color: var(--brutal-mint);
          background: var(--brutal-black);
          padding: 0.5rem 1rem;
          border: 2px solid var(--brutal-mint);
          display: inline-block;
          transform: rotate(-1deg);
        ">
          🤝 ORGANISÉ PAR
        </span>
        
        <!-- Logos -->
        <div class="partner-logos-container">
          <PartnerLogo 
            src="club-alpin-roche-bonneville.svg"
            alt="Club Alpin de La Roche Bonneville"
            backgroundColor="white"
            rotation={-1}
            width="207px"
            height="127px"
          />
          
          <PartnerLogo 
            src="logo-ffme-horizontal.svg" 
            alt="Fédération Française de Montagne et d'Escalade"
            backgroundColor="white"
            rotation={1}
            width="207px"
            height="127px"
          />
        </div>
      </div>
    </div>
    
    <!-- 7. Trait blanc -->
    <BrutalSeparator color="white" width="60%" margin="2rem auto" />
    
    
    <!-- 9. Navigation HIÉRARCHISÉE (PROGRAMME prioritaire) -->
    <div class="hero-navigation" style="
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      grid-template-rows: auto auto;
      gap: 1.5rem 2rem;
      max-width: 900px;
      margin: 3rem auto 0;
      padding: 0 1rem;
      overflow: visible;
    ">
      <!-- PROGRAMME - Bouton principal LARGE (2 colonnes) -->
      <BrutalButton 
        href="#programme" 
        variant="primary" 
        rotation={-1} 
        class="hero-cta-primary"
        ariaLabel="Consulter le programme détaillé des 2 jours de compétition"
      >
        📅 PROGRAMME COMPLET
      </BrutalButton>
      
      <!-- AMBIANCE - Bouton secondaire -->
      <BrutalButton href="#experience" variant="secondary" rotation={1} ariaLabel="Découvrir les témoignages et photos de l'ambiance du championnat">
        🤩 DÉCOUVRIR L'AMBIANCE
      </BrutalButton>
      
      <!-- Ligne 2: Logistique -->
      <BrutalButton href="#pratique" variant="outline" rotation={2} ariaLabel="Informations pratiques : hébergement, transport et restauration">
        🏨 INFOS PRATIQUES
      </BrutalButton>
      <BrutalButton href="#venue" variant="outline" rotation={-2} ariaLabel="Localisation exacte et informations d'accès au complexe sportif">
        📍 LIEU & ACCÈS
      </BrutalButton>
    </div>
    
    <!-- SCROLL INDICATOR - Incite à découvrir le reste -->
    <div class="scroll-indicator" aria-label="Faire défiler pour découvrir plus de contenu">
      <div class="scroll-chevron">
        <span></span>
        <span></span>
      </div>
    </div>
    
  </div>
</section>

<style>
/* HIÉRARCHIE CTA - Programme prioritaire */
.hero-cta-primary {
  grid-column: 1 / -1; /* S'étend sur toute la largeur */
  font-size: 1.125rem;
  font-weight: 900;
  padding: 1.25rem 2rem;
}

.partner-logos-container {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  flex-wrap: wrap;
  justify-content: center;
}

@media (max-width: 768px) {
  .hero-navigation {
    grid-template-columns: minmax(0, 1fr) !important;
    gap: 1rem !important;
    padding: 1rem !important;
    margin-bottom: 2rem;
    overflow: visible !important;
  }

  /* Assurer que tous les boutons sont visibles sur mobile */
  .hero-navigation > * {
    width: 100%;
    margin: 0;
    max-width: 100%;
  }

  /* Supprimer les rotations sur mobile pour éviter débordement */
  .hero-navigation :global(.brutal-button) {
    transform: rotate(0deg) !important;
  }
  
  .partner-logos-container {
    gap: 1rem;
  }
}

@media (max-width: 480px) {
  .partner-logos-container {
    flex-direction: column;
    gap: 0.5rem;
  }
}

/* SCROLL INDICATOR - CSS-only avec animation optimisée */
.scroll-indicator {
  position: absolute;
  bottom: 2rem;
  left: 50%;
  transform: translateX(-50%);
  z-index: 20;
  cursor: pointer;
  opacity: 0.8;
  transition: opacity 0.3s ease;
}

.scroll-indicator:hover {
  opacity: 1;
}

.scroll-chevron {
  position: relative;
  width: 40px;
  height: 40px;
  animation: bounce-down 2s ease-in-out infinite;
}

.scroll-chevron span {
  position: absolute;
  left: 50%;
  width: 12px;
  height: 12px;
  border-right: 3px solid var(--brutal-mint);
  border-bottom: 3px solid var(--brutal-mint);
  transform: translateX(-50%) rotate(45deg);
  animation-fill-mode: both;
}

.scroll-chevron span:first-child {
  top: 8px;
  animation: chevron-1 2s ease-in-out infinite;
}

.scroll-chevron span:nth-child(2) {
  top: 16px;
  animation: chevron-2 2s ease-in-out infinite;
}

/* Animation hardware-accelerated <500ms par cycle */
@keyframes bounce-down {
  0%, 100% { 
    transform: translateY(0);
  }
  50% { 
    transform: translateY(6px);
  }
}

@keyframes chevron-1 {
  0%, 100% { 
    opacity: 0.4;
    transform: translateX(-50%) rotate(45deg);
  }
  50% { 
    opacity: 1;
    transform: translateX(-50%) rotate(45deg) scale(1.1);
  }
}

@keyframes chevron-2 {
  0%, 100% { 
    opacity: 0.7;
    transform: translateX(-50%) rotate(45deg);
  }
  50% { 
    opacity: 1;
    transform: translateX(-50%) rotate(45deg) scale(1.1);
  }
}

/* Accessibilité - Respect prefer-reduced-motion */
@media (prefers-reduced-motion: reduce) {
  .scroll-indicator,
  .scroll-chevron,
  .scroll-chevron span {
    animation: none !important;
  }
  
  .scroll-indicator {
    opacity: 0.6;
  }
}
</style>