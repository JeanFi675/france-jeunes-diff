---
import BrutalHeading from '../atoms/BrutalHeading.astro';
import BrutalBadge from '../atoms/BrutalBadge.astro';
import BrutalButton from '../atoms/BrutalButton.astro';
import BrutalSeparator from '../atoms/BrutalSeparator.astro';
import PartnerLogo from '../atoms/PartnerLogo.astro';
---

<section class="brutal-section brutal-section--black" style="position: relative; overflow: hidden;">
  <!-- Pattern background -->
  <div 
    class="brutal-pattern-diagonal" 
    style="position: absolute; inset: 0; pointer-events: none;"
  ></div>
  
  <!-- Accent blocks -->
  <div style="position: absolute; top: 10%; right: -10%; width: 300px; height: 300px; background: var(--brutal-mint); opacity: 0.1; transform: rotate(45deg);"></div>
  <div style="position: absolute; bottom: -10%; left: -5%; width: 200px; height: 200px; background: var(--brutal-mint); opacity: 0.1; transform: rotate(-30deg);"></div>
  
  <div class="brutal-container" style="position: relative; z-index: 10; text-align: center; padding: 6rem 2rem;">
    
    <!-- 1. Badge entrée gratuite (petit, discret) -->
    <div style="margin-bottom: 1.5rem;">
      <BrutalBadge variant="mint" rotation={2}>
        🎫 ENTRÉE 100% GRATUITE
      </BrutalBadge>
    </div>
    
    <!-- 2. Logo Championnat France 2026 (dominant) -->
    <div style="margin-bottom: 1rem;">
      <img 
        src={`${import.meta.env.BASE_URL}/logo-championnat-france-2026.svg`}
        alt="Championnat de France 2026" 
        style="max-width: 100%; height: auto; width: clamp(400px, 80vw, 900px); margin: 0 auto; display: block; filter: brightness(0) invert(1);"
      />
    </div>
    
    <!-- 3. Sous-titre jeunes de difficulté (vert, plus petit) -->
    <div style="margin: 1rem 0;">
      <BrutalHeading level={2} shadow={false} rotation={0}>
        <span style="color: var(--brutal-mint); text-shadow: none; -webkit-text-stroke: 0; font-size: clamp(2rem, 5vw, 4rem); line-height: 0.9;">
          JEUNES<br>
          DE DIFFICULTÉ
        </span>
      </BrutalHeading>
    </div>
    
    <!-- 4. Trait mint -->
    <BrutalSeparator color="mint" width="60%" margin="2rem auto" />
    
    <!-- 5. Date et lieu (blanc) -->
    <div style="margin: 2rem 0;">
      <BrutalHeading level={2} rotation={0}>
        <span style="color: var(--brutal-white); font-size: clamp(1.25rem, 3vw, 2rem); font-weight: 700; text-shadow: none;">
          16-17 MAI 2026 • SAINT-PIERRE-EN-FAUCIGNY
        </span>
      </BrutalHeading>
    </div>
    
    <!-- 6. Organisé par + logos (layout horizontal) -->
    <div style="margin: 2rem 0;">
      <div style="display: flex; justify-content: center; align-items: center; gap: 2rem; flex-wrap: wrap;">
        <!-- Badge Organisé Par -->
        <span style="
          font-family: 'Inter', Arial, sans-serif;
          font-size: 0.875rem;
          font-weight: 700;
          text-transform: uppercase;
          letter-spacing: 0.1em;
          color: var(--brutal-mint);
          background: var(--brutal-black);
          padding: 0.5rem 1rem;
          border: 2px solid var(--brutal-mint);
          display: inline-block;
          transform: rotate(-1deg);
        ">
          🤝 ORGANISÉ PAR
        </span>
        
        <!-- Logos -->
        <div style="display: flex; align-items: center; gap: 1.5rem;">
          <PartnerLogo 
            src="club-alpin-roche-bonneville.svg"
            alt="Club Alpin de La Roche Bonneville"
            backgroundColor="white"
            rotation={-1}
            width="180px"
            height="110px"
          />
          
          <PartnerLogo 
            src="logo-ffme-horizontal.svg" 
            alt="Fédération Française de Montagne et d'Escalade"
            backgroundColor="white"
            rotation={1}
            width="180px"
            height="110px"
          />
        </div>
      </div>
    </div>
    
    <!-- 7. Trait blanc -->
    <BrutalSeparator color="white" width="60%" margin="2rem auto" />
    
    <!-- 8. Description spectacle (vert) -->
    <p style="font-size: 1.25rem; font-weight: 700; margin: 2rem auto; max-width: 700px; color: var(--brutal-mint);">
      🎪 SPECTACLE GRATUIT • 🏆 ÉLITE FRANÇAISE • 👨‍👩‍👧‍👦 TOUT PUBLIC BIENVENU
    </p>
    
    <!-- 9. Navigation optimisée UX (4 boutons stratégiques) -->
    <div class="hero-navigation" style="
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
      max-width: 900px;
      margin: 3rem auto 0;
    ">
      <!-- Ligne 1: Découverte -->
      <BrutalButton href="#programme" variant="primary" rotation={-1} ariaLabel="Consulter le programme détaillé des 2 jours de compétition">
        📅 PROGRAMME
      </BrutalButton>
      <BrutalButton href="#experience" variant="secondary" rotation={1} ariaLabel="Découvrir les témoignages et photos de l'ambiance du championnat">
        🤩 DÉCOUVRIR L'AMBIANCE
      </BrutalButton>
      
      <!-- Ligne 2: Logistique -->
      <BrutalButton href="#pratique" variant="outline" rotation={2} ariaLabel="Informations pratiques : hébergement, transport et restauration">
        🏨 INFOS PRATIQUES
      </BrutalButton>
      <BrutalButton href="#venue" variant="outline" rotation={-2} ariaLabel="Localisation exacte et informations d'accès au complexe sportif">
        📍 LIEU & ACCÈS
      </BrutalButton>
    </div>
    
  </div>
</section>

<style>
@media (max-width: 768px) {
  .hero-navigation {
    grid-template-columns: 1fr !important;
    gap: 1rem !important;
  }
}
</style>