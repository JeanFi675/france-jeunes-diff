---
const videoUrl = `${import.meta.env.BASE_URL}videos/trailer-web.mp4`;
---

<!-- Modal Trailer -->
<div id="trailer-modal" class="trailer-modal-overlay">
  <div class="trailer-modal-content">
    <button class="trailer-modal-close brutal-modal-close" aria-label="Fermer le trailer">✕</button>
    <video
      id="trailer-video"
      class="trailer-video"
      src={videoUrl}
      controls
      playsinline
      preload="none"
    ></video>
  </div>
</div>

<style>
  .trailer-modal-overlay {
    display: none;
    position: fixed;
    z-index: 1000;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.95);
    align-items: center;
    justify-content: center;
  }

  .trailer-modal-content {
    position: relative;
    height: 90vh;
    width: calc(90vh * 9 / 16);
    max-width: 90vw;
  }

  .trailer-video {
    width: 100%;
    height: 100%;
    display: block;
    border: 4px solid var(--brutal-white);
    box-shadow: 0 0 50px rgba(139, 191, 213, 0.4);
  }

  .trailer-modal-close {
    position: absolute;
    top: -50px;
    right: 0;
    background: var(--brutal-ice);
    color: var(--brutal-black);
    font-size: 2rem;
    font-weight: 900;
    border: none;
    padding: 0.5rem 1rem;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .trailer-modal-close:hover {
    background: var(--brutal-white);
    transform: scale(1.1);
  }

  @media (max-width: 768px) {
    .trailer-modal-content {
      height: 80vh;
      width: calc(80vh * 9 / 16);
      max-width: 92vw;
    }

    .trailer-modal-close {
      font-size: 1.5rem;
      padding: 0.25rem 0.5rem;
      top: -40px;
    }
  }
</style>

<script>
  import { BrutalModal } from '../../scripts/modal-utils';

  document.addEventListener('DOMContentLoaded', () => {
    const video = document.getElementById('trailer-video') as HTMLVideoElement | null;

    const modal = new BrutalModal('trailer-modal', {
      onOpen: () => {
        if (video) {
          video.play().catch(() => {
            // Autoplay bloqué par le navigateur — l'utilisateur cliquera sur play manuellement
          });
        }
      },
      onClose: () => {
        if (video) {
          video.pause();
          video.currentTime = 0;
        }
      },
    });

    window.openTrailerModal = () => modal.open();

    BrutalModal.bindTrigger('[data-open-trailer]', modal);
  });
</script>
