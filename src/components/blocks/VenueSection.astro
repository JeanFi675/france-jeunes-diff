---
import BrutalHeading from '../atoms/BrutalHeading.astro';
import BrutalButton from '../atoms/BrutalButton.astro';
import BrutalBadge from '../atoms/BrutalBadge.astro';

export interface Props {
  id?: string;
}

const { id } = Astro.props;

// URL directe vers Google Maps
const googleMapsUrl = "https://maps.app.goo.gl/tPkif9FKYX3g7BoVA";

// URL pour directions Google Maps
const directionsUrl = "https://www.google.com/maps/dir//Complexe+Sportif+du+Pays+Rochois,+110+Rue+des+Alpes,+74800+Saint-Pierre-en-Faucigny/@46.0644,6.3698";

// URL pour iframe Google Maps (embed)
const embedMapUrl = "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2771.8!2d6.3698!3d46.0644!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNDbCsDAzJzUyLjAiTiA2wrAyMicxMS4zIkU!5e0!3m2!1sfr!2sfr!4v1000000000000!5m2!1sfr!2sfr";
---

<section id={id} class="brutal-section" style="background: var(--brutal-black); color: var(--brutal-white); position: relative;">
  <!-- Pattern background -->
  <div class="brutal-pattern-dots" style="position: absolute; inset: 0; opacity: 0.1;"></div>
  
  <div class="brutal-container" style="position: relative; z-index: 10;">
    <div style="text-align: center; margin-bottom: 4rem;">
      <BrutalHeading level={2} shadow={true} class="brutal-title brutal-title--white" rotation={-1}>
        COMPLEXE SPORTIF<br>
        <span style="color: var(--brutal-mint);">DU PAYS ROCHOIS</span>
      </BrutalHeading>
    </div>
    
    <div class="brutal-grid" style="grid-template-columns: 1fr 1fr; align-items: center; gap: 4rem;">
      <!-- Carte statique -->
      <div style="position: relative;">
        <div style="transform: rotate(-2deg); border: 8px solid var(--brutal-mint); box-shadow: 12px 12px 0 var(--brutal-white); overflow: hidden;">
          <iframe 
            src={embedMapUrl}
            width="600" 
            height="400"
            style="border: 0; display: block; width: 100%; height: 400px;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Complexe sportif du Pays Rochois - Localisation"
          ></iframe>
        </div>
        
        <!-- Badge sur la carte -->
        <div style="position: absolute; top: -10px; right: -10px; transform: rotate(15deg);">
          <BrutalBadge variant="mint">
            📍 SAINT-PIERRE-EN-FAUCIGNY
          </BrutalBadge>
        </div>
      </div>
      
      <!-- Infos lieu -->
      <div>
        <div class="brutal-grid" style="grid-template-columns: 1fr 1fr 1fr; gap: 1rem; margin-bottom: 3rem;">
          <!-- Stat 1 -->
          <div 
            class="brutal-card brutal-card--mint" 
            style="text-align: center; transform: rotate(-2deg);"
          >
            <div style="font-family: 'Inter', sans-serif; font-weight: 800; font-size: 3rem; line-height: 1; color: var(--brutal-black);">
              13M
            </div>
            <div style="font-weight: 700; font-size: 0.875rem; text-transform: uppercase; color: var(--brutal-black);">
              HAUTEUR
            </div>
          </div>
          
          <!-- Stat 2 -->
          <div 
            class="brutal-card" 
            style="text-align: center; transform: rotate(1deg);"
          >
            <div style="font-family: 'Inter', sans-serif; font-weight: 800; font-size: 3rem; line-height: 1; color: var(--brutal-black);">
              705M²
            </div>
            <div style="font-weight: 700; font-size: 0.875rem; text-transform: uppercase; color: var(--brutal-black);">
              SURFACE
            </div>
          </div>
          
          <!-- Stat 3 -->
          <div 
            class="brutal-card brutal-card--mint" 
            style="text-align: center; transform: rotate(-1deg);"
          >
            <div style="font-family: 'Inter', sans-serif; font-weight: 800; font-size: 3rem; line-height: 1; color: var(--brutal-black);">
              300
            </div>
            <div style="font-weight: 700; font-size: 0.875rem; text-transform: uppercase; color: var(--brutal-black);">
              GRIMPEURS
            </div>
          </div>
        </div>
        
        <!-- Adresse -->
        <div class="brutal-card brutal-card--black" style="margin-bottom: 2rem; transform: rotate(1deg);">
          <div style="font-weight: 900; font-size: 1.25rem; color: var(--brutal-mint); margin-bottom: 0.5rem;">
            📍 ADRESSE
          </div>
          <div style="color: var(--brutal-white); font-size: 1.125rem;">
            110 rue des Alpes<br>
            74800 Saint-Pierre-en-Faucigny
          </div>
        </div>
        
        <!-- Boutons -->
        <div class="brutal-flex" style="flex-direction: column; gap: 1rem;">
          <BrutalButton href={googleMapsUrl} variant="primary" rotation={-1}>
            🧭 OUVRIR DANS GOOGLE MAPS
          </BrutalButton>
          <BrutalButton href={directionsUrl} variant="outline" rotation={2}>
            🚗 ITINÉRAIRE DÉTAILLÉ
          </BrutalButton>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @media (max-width: 768px) {
    .brutal-grid {
      grid-template-columns: 1fr !important;
    }
  }
</style>