---
import BaseLayout from '../components/layout/BaseLayout.astro';

// Import tous les blocs selon LANDING_PAGE_SPECS.md
import HeroSection from '../components/blocks/HeroSection.astro';
import EventDateSection from '../components/blocks/EventDateSection.astro';
import ProgramSection from '../components/blocks/ProgramSection.astro';
import VenueSection from '../components/blocks/VenueSection.astro';
import StatsSection from '../components/blocks/StatsSection.astro';
import CTASection from '../components/blocks/CTASection.astro';

const metadata = {
  title: 'Championnats de France Jeunes Difficulté 2026',
  description: 'Championnats de France Jeunes Difficulté d\'escalade - 16-17 mai 2026 • Saint-Pierre-en-Faucigny'
};
---

<BaseLayout title={metadata.title} description={metadata.description}>
  <!-- BLOC 1: Hero Section -->
  <HeroSection />
  
  <!-- BLOC 2: Date de l'événement (pas de countdown) -->
  <EventDateSection />
  
  <!-- BLOC 3: Programme -->
  <ProgramSection />
  
  <!-- BLOC 4: Lieu & Accès -->
  <VenueSection />
  
  <!-- BLOC 5: Stats Impact -->
  <StatsSection />
  
  <!-- BLOC 6: CTA Final -->
  <CTASection />
</BaseLayout>