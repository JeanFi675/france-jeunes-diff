---
import BaseLayout from '../components/layout/BaseLayout.astro';

// Import tous les blocs selon TODO_OPTIMIZED_DEV_JUNIOR.md (DRY)
import HeroSection from '../components/blocks/HeroSection.astro';
import PublicWelcomeSection from '../components/blocks/PublicWelcomeSection.astro';
import ProgramSection from '../components/blocks/ProgramSection.astro';
import PracticalInfoSection from '../components/blocks/PracticalInfoSection.astro';
import VenueSection from '../components/blocks/VenueSection.astro';
import StatsSection from '../components/blocks/StatsSection.astro';
import ExperienceSection from '../components/blocks/ExperienceSection.astro';
import CTASection from '../components/blocks/CTASection.astro';

const metadata = {
  title: 'Championnats de France Jeunes de Difficulté 2026',
  description: 'Championnats de France Jeunes de Difficulté d\'escalade - 16-17 mai 2026 • Saint-Pierre-en-Faucigny • ENTRÉE GRATUITE • Spectacle familial'
};
---

<BaseLayout title={metadata.title} description={metadata.description}>
  <!-- HERO: Accroche vendeuse avec countdown intégré (FUSION UX 2025) -->
  <HeroSection />
  
  <!-- PUBLIC: Info public + compétiteurs + météo -->
  <PublicWelcomeSection />
  
  <!-- PROGRAMME: Horaires des 2 jours -->
  <ProgramSection background="black" />
  
  <!-- PRATIQUE: Hébergement + Transport + Restauration (fusion DRY) -->
  <PracticalInfoSection />
  
  <!-- STATS: Chiffres d'impact (REPOSITIONNÉ pour respiration cognitive) -->
  <StatsSection />
  
  <!-- VENUE: Lieu avec carte iframe (id="venue" pour navigation) -->
  <VenueSection id="venue" />
  
  <!-- EXPERIENCE: Galerie + Témoignages (id="experience" pour navigation) -->
  <ExperienceSection />
  
  <!-- CTA: Appel à l'action final -->
  <CTASection />
</BaseLayout>